rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }

    // Profiles: anyone can read; you can only write your own.
    match /users/{uid} {
      allow read: if true;
      allow write: if signedIn() && request.auth.uid == uid;
    }

    // Follow lists: doc id = the follower's uid; only they can edit it.
    match /follows/{uid} {
      allow read: if true;
      allow write: if signedIn() && request.auth.uid == uid;
    }

    // Tracks: public to read; only the owner can create/edit/delete.
    match /tracks/{id} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    // Statuses (wall posts): public to read; only the author can manage.
    match /statuses/{id} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    // Comments: public to read; only the comment's author can edit/delete it.
    match /comments/{id} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    // Likes/dislikes (arrays of user ids): any signed-in user may react.
    match /reactions/{id} {
      allow read: if true;
      allow write: if signedIn();
    }

    // Notifications: a signed-in user can create one for someone else;
    // the recipient can read and mark their own as read.
    match /notifications/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.fromUid == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.forUid == request.auth.uid;
    }

    // Suggestion box: anyone signed in can submit; reads are console-only.
    match /suggestions/{id} {
      allow create: if signedIn();
      allow read, update, delete: if false;
    }

    // Marketplace sellers: owner writes, signed-in users read.
    match /sellers/{uid} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == uid;
    }

    // Products: public to read; only the listing seller can write.
    match /products/{id} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.sellerId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.sellerId == request.auth.uid;
    }

    // Orders: buyer creates; buyer can read their own.
    match /orders/{id} {
      allow create: if signedIn() && request.resource.data.buyerId == request.auth.uid;
      allow read: if signedIn() && resource.data.buyerId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
