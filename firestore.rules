rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }

    match /users/{uid} {
      allow read: if true;
      allow write: if signedIn() && request.auth.uid == uid;

      match /sessions/{sessionId} {
        allow read, write: if signedIn() && request.auth.uid == uid;
      }

      match /activityLog/{logId} {
        allow read: if signedIn() && request.auth.uid == uid;
        allow create: if signedIn() && request.auth.uid == uid;
        allow update, delete: if false;
      }
    }

    match /follows/{uid} {
      allow read: if true;
      allow write: if signedIn() && request.auth.uid == uid;
    }

    match /tracks/{id} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /statuses/{id} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /comments/{id} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /reactions/{id} {
      allow read: if true;
      allow write: if signedIn();
    }

    match /notifications/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && (
        request.resource.data.fromUid == request.auth.uid ||
        (request.auth.token.email == "trendai509@gmail.com" && request.resource.data.fromUid == "platform")
      );
      allow update, delete: if signedIn() && resource.data.forUid == request.auth.uid;
    }

    match /suggestions/{id} {
      allow create: if signedIn();
      allow read: if request.auth != null && request.auth.token.email == "trendai509@gmail.com";
      allow update, delete: if false;
    }

    match /reports/{id} {
      allow create: if signedIn() && request.resource.data.reporterUid == request.auth.uid;
      allow read: if request.auth != null && request.auth.token.email == "trendai509@gmail.com";
      allow update, delete: if false;
    }

    match /sellers/{uid} {
      allow read: if true;
      allow write: if signedIn() && request.auth.uid == uid;
    }

    match /products/{id} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.sellerId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.sellerId == request.auth.uid;
    }

    match /orders/{id} {
      allow create: if signedIn() && request.resource.data.buyerId == request.auth.uid;
      allow read: if signedIn() && (
        resource.data.buyerId == request.auth.uid ||
        request.auth.token.email == "trendai509@gmail.com"
      );
      allow update, delete: if false;
    }

    match /messages/{convId} {
      allow read, update: if signedIn() && request.auth.uid in resource.data.participants;
      allow create: if signedIn() && request.auth.uid in request.resource.data.participants;

      match /msgs/{msgId} {
        allow read: if signedIn() && request.auth.uid in get(/databases/$(database)/documents/messages/$(convId)).data.participants;
        allow create: if signedIn() && request.resource.data.senderId == request.auth.uid;
        // sender or recipient can edit (edit text, delete for me, delete for everyone)
        allow update: if signedIn() && request.auth.uid in get(/databases/$(database)/documents/messages/$(convId)).data.participants;
        allow delete: if false;
      }
    }

    match /followRequests/{reqId} {
      allow read: if signedIn() && (
        resource.data.fromUid == request.auth.uid ||
        resource.data.toUid == request.auth.uid
      );
      allow create: if signedIn() && request.resource.data.fromUid == request.auth.uid;
      allow update: if signedIn() && resource.data.toUid == request.auth.uid;
      allow delete: if signedIn() && (
        resource.data.fromUid == request.auth.uid ||
        resource.data.toUid == request.auth.uid
      );
    }

    match /calls/{callId} {
      allow create: if signedIn() && request.resource.data.callerId == request.auth.uid;
      allow read, update: if signedIn() && (
        resource.data.callerId == request.auth.uid ||
        resource.data.calleeId == request.auth.uid
      );
      allow delete: if false;
    }

    match /wallets/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || resource.data.isPublic == true);
      // Owner has full control of their own wallet
      allow create, update: if signedIn() && request.auth.uid == uid;
      // Any signed-in user can credit another wallet (P2P transfer / rewards)
      // Guard: balance & totalEarned can only increase; totalSpent must stay the same
      allow update: if signedIn() && request.auth.uid != uid
        && request.resource.data.balance >= resource.data.balance
        && request.resource.data.totalEarned >= resource.data.totalEarned
        && request.resource.data.totalSpent == resource.data.totalSpent;
      // Allow creating a wallet for a user who has none (first-time credit)
      // balance must equal totalEarned — prevents minting arbitrary initial balances
      allow create: if signedIn() && request.auth.uid != uid
        && request.resource.data.totalSpent == 0
        && request.resource.data.balance == request.resource.data.totalEarned;

      match /transactions/{txId} {
        allow read: if signedIn() && request.auth.uid == uid;
        allow create: if signedIn();
        allow update, delete: if false;
      }
    }

    match /transfers/{id} {
      allow create: if signedIn() && request.resource.data.fromUid == request.auth.uid;
      allow read: if signedIn() && (
        resource.data.fromUid == request.auth.uid ||
        resource.data.toUid == request.auth.uid
      );
      allow update, delete: if false;
    }

    match /followRewards/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.followerId == request.auth.uid;
      allow update, delete: if false;
    }

    match /viewLogs/{logId} {
      allow create: if signedIn() && request.resource.data.viewerUid == request.auth.uid;
      allow read: if false;
      allow update, delete: if false;
    }
  }
}
